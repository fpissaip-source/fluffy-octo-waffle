# Alpaca API Credentials (https://app.alpaca.markets/)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Watchlist (comma-separated)
WATCHLIST=AAPL,TSLA,NVDA,AMD,META,MSFT,GOOGL,AMZN

# Risk
MAX_POSITION_PCT=0.10
KELLY_FRACTION=0.25
MIN_EV_GAP=0.02

# Timing
SCAN_INTERVAL=30

# Logging
LOG_LEVEL=INFO

# Telegram (fuer iPhone-Steuerung)
# 1. Oeffne Telegram → suche @BotFather → /newbot
# 2. Kopiere den Token hierhin
# 3. Sende /start an deinen neuen Bot
# 4. Oeffne https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Kopiere die chat_id hierhin
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Claude API (OPTIONAL — fuer Deep Sentiment Analysis)
# Ohne Key funktioniert der Bot normal, nur ohne Claude-Analyse
# ANTHROPIC_API_KEY=sk-ant-...
